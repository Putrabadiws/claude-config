{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "WebSearch",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",

      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(sort *)",
      "Bash(uniq *)",

      "Bash(uname *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(whereis *)",
      "Bash(command -v *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(basename *)",
      "Bash(date *)",

      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git remote -v)",
      "Bash(git rev-parse *)",
      "Bash(git rev-list *)",
      "Bash(git ls-files *)",
      "Bash(git describe *)",
      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git stash list)",

      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh repo view *)",
      "Bash(gh api *)",

      "Bash(chmod +x *)",
      "Bash(bash *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(xargs *)",
      "Bash(tee *)",

      "Bash(brew --version)",
      "Bash(brew list *)",
      "Bash(kubectl config current-context)",
      "Bash(claude --version)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)"
    ]
  }
}
