{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "✨ Generated with Claude Code (claude.ai/claude-code) {version} ({model})",
    "pr": "✨ Generated with Claude Code (claude.ai/claude-code) {version} ({model})"
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "false"
  },
  "permissions": {
    "default": "ask",
    "allow": [
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.github.com)",
      "Read",
      "WebSearch",

      "Skill(mr-review)",
      "Skill(commit)",
      "Skill(k8s)",
      "Skill(logs)",

      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(open:*)",
      "Bash(* --version)",
      "Bash(* --help)",

      "Bash(go mod tidy)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(golangci-lint:*)",

      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx eslint:*)",
      "Bash(node --check:*)",

      "Bash(./mvnw compile:*)",
      "Bash(./mvnw test:*)",
      "Bash(./mvnw clean:*)",
      "Bash(./mvnw spring-boot:run:*)",

      "Bash(pytest:*)",
      "Bash(ruff check:*)",
      "Bash(pip install:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git ls-tree:*)",
      "Bash(git stash list)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git remote -v)",
      "Bash(git submodule:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git ls-files:*)",
      "Bash(git describe:*)",

      "Bash(git -C * status:*)",
      "Bash(git -C * log:*)",

      "Bash(gh auth status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh api repos/*/pulls/*/comments)",

      "Bash(kubectl get:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl config:*)",
      "Bash(kubectl top:*)",

      "Bash(kubectl * get pods:*)",
      "Bash(kubectl * get configmap:*)",
      "Bash(kubectl * logs:*)",
      "Bash(kubectl * describe:*)",
      "Bash(kubectl * config:*)",
      "Bash(kubectl * top:*)",

      "Bash(helm template:*)",
      "Bash(helm list:*)",
      "Bash(helm status:*)",

      "Bash(dig:*)",
      "Bash(curl:*)",
      "Bash(brew list:*)",

      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cut:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(xargs:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(whereis:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(comm:*)",
      "Bash(tee:*)",

      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(uname:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(basename:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp -r:*)",
      "Bash(brew install:*)",

      "Bash(go mod init:*)",

      "Bash(git init:*)",
      "Bash(git branch -D:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git stash)",
      "Bash(git stash pop:*)",
      "Bash(git revert:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git merge:*)",
      "Bash(git remote set-url:*)",

      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh issue close:*)",
      "Bash(gh api -X:*)",

      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",
      "Bash(kubectl merge:*)",
      "Bash(kubectl restart:*)",

      "Bash(kubectl * apply:*)",
      "Bash(kubectl * rollout:*)",
      "Bash(kubectl * merge:*)",
      "Bash(kubectl * restart:*)",
      "Bash(kubectl * delete:*)",
      "Bash(kubectl * exec:*)",
      "Bash(kubectl * port-forward:*)",

      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",

      "Bash(tar:*)",
      "Bash(xcodebuild:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/credentials*)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(* > /dev/sd*)",
      "Bash(dd if=*)",
      "Bash(mkfs.*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allowManagedPermissionRulesOnly": "true",
    "additionalDirectories": [
      "<workspace>/bangor-claude-config/**",
      "~/.claude/**",
      "/tmp/**"
    ]
  }
}
