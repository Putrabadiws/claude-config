{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "Read(*)",
      "WebSearch",

      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(start *)",
      "Bash(explorer *)",

      "Bash(go mod tidy)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go run *)",
      "Bash(golangci-lint *)",

      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx eslint *)",
      "Bash(node --check *)",

      "Bash(./mvnw compile *)",
      "Bash(./mvnw test *)",
      "Bash(./mvnw clean *)",
      "Bash(./mvnw spring-boot:run *)",

      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(pip install *)",

      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git stash list)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git remote -v)",
      "Bash(git submodule *)",

      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",

      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl config *)",
      "Bash(kubectl top *)",

      "Bash(helm template *)",
      "Bash(helm list *)",
      "Bash(helm status *)",

      "Bash(curl *)",
      "Bash(winget search *)",
      "Bash(winget list *)",
      "Bash(choco list *)",
      "Bash(ipconfig *)",
      "Bash(netstat *)",
      "Bash(nslookup *)",

      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git rev-list *)",
      "Bash(git ls-files *)",
      "Bash(git describe *)",

      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(tee *)",

      "Bash(date *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(uname *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(basename *)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp -r:*)",

      "Bash(git branch -D *)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git stash)",
      "Bash(git stash pop:*)",
      "Bash(git revert:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git merge:*)",
      "Bash(git remote set-url:*)",

      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh api -X *)",

      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",

      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",

      "Bash(tar:*)",
      "Bash(docker:*)",

      "WebFetch(*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/credentials*)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(dd if=*)",
      "Bash(format *:)",
      "Bash(diskpart *)",
      "Bash(chmod 777 *)",
      "Bash(runas *)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-claude-version.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/validate-destructive.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/github-context.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/bangor-context.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/validate-db-readonly.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/docs-check.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/require-tests.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lint-check.sh",
            "async": true,
            "timeout": 30,
            "statusMessage": "Linting file..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-pr-after-push.sh",
            "if": "Bash(git push *)",
            "timeout": 15,
            "statusMessage": "Checking PR status..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cleanup-settings-local.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-context.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-config-update.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cleanup-settings-local.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
