{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "✨ Generated with Claude Code (claude.ai/claude-code) {version} ({model})",
    "pr": "✨ Generated with Claude Code (claude.ai/claude-code) {version} ({model})"
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": false
  },
  "permissions": {
    "default": "ask",
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allowManagedPermissionRulesOnly": "true",
    "allow": [
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.github.com)",
      "Read(*)",
      "WebSearch",

      "Skill(mr-review)",
      "Skill(commit)",
      "Skill(k8s)",
      "Skill(logs)",

      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(start *)",
      "Bash(explorer *)",
      "Bash(* --version)",
      "Bash(* --help)",

      "Bash(go mod tidy)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go run *)",
      "Bash(golangci-lint *)",

      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx eslint *)",
      "Bash(node --check *)",

      "Bash(./mvnw compile *)",
      "Bash(./mvnw test *)",
      "Bash(./mvnw clean *)",
      "Bash(./mvnw spring-boot:run *)",

      "Bash(pytest *)",
      "Bash(ruff check *)",
      "Bash(pip install *)",

      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git stash list)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git remote -v)",
      "Bash(git submodule *)",

      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh api *)",
      "Bash(gh repo view *)",
      "Bash(gh run view *)",

      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl config *)",
      "Bash(kubectl top *)",

      "Bash(helm template *)",
      "Bash(helm list *)",
      "Bash(helm status *)",

      "Bash(curl *)",
      "Bash(winget search *)",
      "Bash(winget list *)",
      "Bash(choco list *)",
      "Bash(ipconfig *)",
      "Bash(netstat *)",
      "Bash(nslookup *)",

      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git rev-list *)",
      "Bash(git ls-files *)",
      "Bash(git describe *)",

      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(comm *)",
      "Bash(tee *)",

      "Bash(date *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(uname *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(basename *)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp -r:*)",

      "Bash(go mod init:*)",

      "Bash(git branch -D *)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git stash)",
      "Bash(git stash pop:*)",
      "Bash(git revert:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git merge:*)",
      "Bash(git remote set-url:*)",

      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh issue close:*)",
      "Bash(gh api -X *)",

      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl rollout:*)",
      "Bash(kubectl exec:*)",
      "Bash(kubectl port-forward:*)",

      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",

      "Bash(tar:*)",
      "Bash(docker:*)"
    ],
    "deny": [
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/credentials*)",

      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(dd if=*)",
      "Bash(format *:)",
      "Bash(diskpart *)",
      "Bash(chmod 777 *)",
      "Bash(runas *)"
    ],
    "additionalDirectories": [
      "<workspace>/bangor-claude-config/*",
      "~/.claude/*"
    ]
  }
}
